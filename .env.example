# Vanguard-CX Environment Variables
# Copy to .env and fill in values

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=8080
DATABASE_URL=file:vanguard.db?cache=shared&mode=rwc&_journal_mode=WAL

# ── Agent Worker ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...          # Optional: enables live LLM reasoning
BACKEND_URL=http://localhost:8080
POLL_INTERVAL_MS=5000

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Leave blank for same-origin (when behind Nginx)
VITE_API_URL=
VITE_WS_URL=
